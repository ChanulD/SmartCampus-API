<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Smart Campus API</display-name>

    <!--
        No explicit servlet registration needed.

        Jersey's ServletContainerInitializer (in jersey-container-servlet.jar)
        implements the Servlet 3.0 javax.servlet.ServletContainerInitializer SPI.
        On startup, Tomcat calls it, it scans for classes annotated with
        @ApplicationPath, finds SmartCampusApplication, and auto-registers
        org.glassfish.jersey.servlet.ServletContainer mapped to /api/v1/*.

        Benefits of this approach:
          - No ClassCastException (ResourceConfig is not cast to Servlet)
          - No path-mapping conflicts between url-pattern and @ApplicationPath
          - Single source of truth for the base path: @ApplicationPath("/api/v1")
    -->

</web-app>
